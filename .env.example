# Habbo Pixel Agents — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# GitHub repo to monitor for Copilot coding agent activity.
# Format: owner/repo  (e.g. AventusM/habbo-pixel-agents)
GITHUB_REPO=owner/repo

# GitHub Personal Access Token with read:repo and read:actions scopes.
# Required for the Copilot agent monitor to poll PRs and workflow runs.
GITHUB_TOKEN=ghp_...

# How often to poll GitHub for Copilot agent updates (seconds). Default: 15
# GITHUB_POLL_INTERVAL=15

# Azure DevOps integration (optional — leave blank to disable)
AZDO_ORG=
AZDO_PROJECT=
AZDO_PAT=
# AZDO_POLL_INTERVAL=60

# HTTP port for the web server. Default: 3000
# PORT=3000
