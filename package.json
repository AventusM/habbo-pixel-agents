{
  "name": "habbo-pixel-agents",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/extension.cjs",
  "engines": {
    "vscode": "^1.80.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "habbo-pixel-agents.openRoom",
        "title": "Open Habbo Room"
      }
    ]
  },
  "scripts": {
    "prebuild": "echo 'Asset extraction deferred to Plan 03-03'",
    "build:ext": "node esbuild.config.mjs extension",
    "build:webview": "node esbuild.config.mjs webview",
    "build": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.109.0",
    "esbuild": "^0.27.3",
    "happy-dom": "^20.7.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
