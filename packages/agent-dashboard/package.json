{
  "name": "@anthropic-claude/agent-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time web dashboard for GitHub Copilot coding agents",
  "type": "module",
  "bin": {
    "agent-dashboard": "./bin/agent-dashboard.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./src/index.ts"
    },
    "./client": {
      "import": "./dist/client.mjs",
      "types": "./src/client.ts"
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.0"
  }
}
